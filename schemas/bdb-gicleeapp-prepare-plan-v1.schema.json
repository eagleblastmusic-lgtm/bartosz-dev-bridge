{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bdb-gicleeapp-prepare-plan-v1",
  "title": "BDB GicleeApp Prepare proposal v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "repository_full_name", "default_branch_hint", "repository_identity_verification",
    "alias", "source_repo", "workspace_root", "observed_branch", "allowed_paths",
    "python_executable", "test_timeout_seconds", "requires_confirmation", "read_only",
    "mutation_operations_invoked"
  ],
  "properties": {
    "schema": { "const": "bdb-gicleeapp-prepare-plan-v1" },
    "repository_full_name": { "const": "eagleblastmusic-lgtm/gicleeart" },
    "default_branch_hint": { "const": "master" },
    "repository_identity_verification": { "const": "external_required" },
    "alias": { "const": "gicleeart" },
    "source_repo": { "type": "string", "minLength": 1 },
    "workspace_root": { "type": "string", "minLength": 1 },
    "observed_branch": { "type": "string", "minLength": 1 },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "python_executable": { "type": "string", "minLength": 1 },
    "test_timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
    "requires_confirmation": { "const": true },
    "read_only": { "const": true },
    "mutation_operations_invoked": { "const": 0 }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bdb-gui-diagnostics-v1",
  "title": "BDB GUI bounded diagnostics snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "workspace_root", "generated_at", "complete", "project_alias",
    "read_only", "mutation_operations_invoked", "redaction_version", "versions", "sections"
  ],
  "properties": {
    "schema": { "const": "bdb-gui-diagnostics-v1" },
    "workspace_root": { "type": "string" },
    "generated_at": { "type": "string" },
    "complete": { "type": "boolean" },
    "project_alias": { "type": ["string", "null"] },
    "read_only": { "const": true },
    "mutation_operations_invoked": { "const": 0 },
    "redaction_version": { "const": "bdb-redaction-v1" },
    "versions": { "type": "object", "additionalProperties": { "type": "string" } },
    "sections": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema", "name", "ok", "operation_id", "project_alias", "data", "error"],
        "properties": {
          "schema": { "const": "bdb-gui-diagnostics-section-v1" },
          "name": { "enum": ["capabilities", "status", "current_operation", "logs", "collection"] },
          "ok": { "type": "boolean" },
          "operation_id": { "type": "string" },
          "project_alias": { "type": ["string", "null"] },
          "data": { "type": "object" },
          "error": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["code", "message"],
                "properties": {
                  "code": { "type": ["string", "null"] },
                  "message": { "type": ["string", "null"] }
                }
              }
            ]
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bdb-gui-control-result-v1",
  "title": "BDB Control Center explicit process-control result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "action",
    "workspace_root",
    "project_alias",
    "operator_operation_id",
    "ok",
    "mutation_operations_invoked",
    "operator_data",
    "error"
  ],
  "properties": {
    "schema": { "const": "bdb-gui-control-result-v1" },
    "action": { "enum": ["start", "stop", "rearm"] },
    "workspace_root": { "type": "string", "minLength": 1 },
    "project_alias": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9-]{0,31}$"
    },
    "operator_operation_id": { "type": "string", "minLength": 1 },
    "ok": { "type": "boolean" },
    "mutation_operations_invoked": { "const": 1 },
    "operator_data": { "type": "object" },
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "type": ["string", "null"] },
            "message": { "type": ["string", "null"] }
          }
        }
      ]
    }
  }
}

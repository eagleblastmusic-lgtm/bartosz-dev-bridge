{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bdb-gui-prepare-plan-v1",
  "title": "BDB GUI project prepare plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "alias", "workspace_root", "source_repo", "allowed_paths",
    "python_executable", "test_timeout_seconds", "max_patch_bytes",
    "max_changed_files", "auto_send_max_bytes", "worker_timeout_seconds",
    "native_config", "requires_confirmation", "preflight_owner", "read_only",
    "mutation_operations_invoked"
  ],
  "properties": {
    "schema": { "const": "bdb-gui-prepare-plan-v1" },
    "alias": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
    "workspace_root": { "type": "string" },
    "source_repo": { "type": "string" },
    "allowed_paths": { "type": "array", "minItems": 1, "maxItems": 100, "uniqueItems": true, "items": { "type": "string" } },
    "python_executable": { "type": "string" },
    "test_timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
    "max_patch_bytes": { "type": "integer", "minimum": 1, "maximum": 16777216 },
    "max_changed_files": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "auto_send_max_bytes": { "type": "integer", "minimum": 1, "maximum": 1048576 },
    "worker_timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
    "native_config": { "type": ["string", "null"] },
    "requires_confirmation": { "const": true },
    "preflight_owner": { "const": "existing_prepare_workspace_loop" },
    "read_only": { "const": true },
    "mutation_operations_invoked": { "const": 0 }
  }
}

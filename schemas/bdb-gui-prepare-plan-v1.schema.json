{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bdb-gui-prepare-plan-v1",
  "title": "BDB GUI project prepare plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "alias", "workspace_root", "source_repo", "allowed_paths",
    "python_executable", "test_timeout_seconds", "requires_confirmation",
    "preflight_owner", "read_only", "mutation_operations_invoked"
  ],
  "properties": {
    "schema": { "const": "bdb-gui-prepare-plan-v1" },
    "alias": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,31}$" },
    "workspace_root": { "type": "string", "minLength": 1 },
    "source_repo": { "type": "string", "minLength": 1 },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "python_executable": { "type": "string", "minLength": 1 },
    "test_timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
    "requires_confirmation": { "const": true },
    "preflight_owner": { "const": "existing_prepare_workspace_loop" },
    "read_only": { "const": true },
    "mutation_operations_invoked": { "const": 0 }
  }
}

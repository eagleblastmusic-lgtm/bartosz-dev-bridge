{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bdb-gui-history-v1",
  "title": "BDB GUI bounded Journal history v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "workspace_root",
    "project_alias",
    "ok",
    "read_only",
    "mutation_operations_invoked",
    "operator_operation_id",
    "events",
    "cursor",
    "filters",
    "error"
  ],
  "properties": {
    "schema": { "const": "bdb-gui-history-v1" },
    "workspace_root": { "type": "string" },
    "project_alias": { "type": ["string", "null"] },
    "ok": { "type": "boolean" },
    "read_only": { "const": true },
    "mutation_operations_invoked": { "const": 0 },
    "operator_operation_id": { "type": "string" },
    "events": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema",
          "event_id",
          "sequence",
          "event_type",
          "occurred_at",
          "source",
          "severity",
          "correlation_id",
          "session_id",
          "command_id",
          "payload"
        ],
        "properties": {
          "schema": { "const": "bdb-gui-event-v1" },
          "event_id": { "type": "string" },
          "sequence": { "type": "integer", "minimum": 0 },
          "event_type": { "type": "string" },
          "occurred_at": { "type": "string" },
          "source": { "type": "string" },
          "severity": { "type": "string" },
          "correlation_id": { "type": ["string", "null"] },
          "session_id": { "type": ["string", "null"] },
          "command_id": { "type": ["string", "null"] },
          "payload": { "type": "object" }
        }
      }
    },
    "cursor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["after_event_id", "next_after_event_id", "has_more"],
      "properties": {
        "after_event_id": { "type": "integer", "minimum": 0 },
        "next_after_event_id": { "type": "integer", "minimum": 0 },
        "has_more": { "type": "boolean" }
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "command_id"],
      "properties": {
        "session_id": { "type": ["string", "null"] },
        "command_id": { "type": ["string", "null"] }
      }
    },
    "error": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "type": ["string", "null"] },
            "message": { "type": ["string", "null"] }
          }
        }
      ]
    }
  }
}

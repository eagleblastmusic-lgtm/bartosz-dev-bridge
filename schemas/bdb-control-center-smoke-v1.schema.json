{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bdb-control-center-smoke-v1",
  "title": "BDB Control Center headless smoke report v1",
  "type": "object",
  "required": ["schema", "status"],
  "properties": {
    "schema": { "const": "bdb-control-center-smoke-v1" },
    "status": { "enum": ["success", "failed"] },
    "window_object_name": { "type": "string" },
    "window_constructed": { "type": "boolean" },
    "read_only_startup": { "const": true },
    "navigation": { "type": "array", "items": { "type": "string" }, "maxItems": 5 },
    "page_count": { "type": "integer", "minimum": 0, "maximum": 5 },
    "project_count": { "type": "integer", "minimum": 0 },
    "bootstrap_completed": { "type": "boolean" },
    "bootstrap_ok": { "type": "boolean" },
    "bootstrap_error_code": { "type": ["string", "null"] },
    "mutation_operations_invoked": { "const": 0 },
    "operator_network_listener": { "type": ["boolean", "null"] },
    "selected_workspace_root": { "type": ["string", "null"] },
    "status_read_completed": { "type": "boolean" },
    "status_read_ok": { "type": ["boolean", "null"] },
    "status_error_code": { "type": ["string", "null"] },
    "action_controls_present": { "type": "boolean" },
    "confirmation_required": { "const": true },
    "arm_minutes_min": { "type": "integer", "minimum": 1, "maximum": 60 },
    "arm_minutes_max": { "type": "integer", "minimum": 1, "maximum": 60 },
    "project_available": { "type": "boolean" },
    "dashboard_busy": { "type": "boolean" },
    "projects_wizard_present": { "const": true },
    "prepare_plan_required": { "const": true },
    "prepare_confirmation_required": { "const": true },
    "prepare_plan_loaded": { "type": "boolean" },
    "current_operation_view_present": { "type": "boolean" },
    "current_operation_read_only": { "const": true },
    "current_operation_refresh_present": { "type": "boolean" },
    "current_operation_loaded": { "type": "boolean" },
    "current_operation_active": { "type": ["boolean", "null"] },
    "operation_flow_present": { "type": "boolean" },
    "operation_flow_status": { "enum": ["pending", "active", "success", "failed"] },
    "history_view_present": { "type": "boolean" },
    "history_read_only": { "const": true },
    "history_pagination_present": { "type": "boolean" },
    "history_filters_present": { "type": "boolean" },
    "history_loaded": { "type": "boolean" },
    "history_event_count": { "type": "integer", "minimum": 0 },
    "history_tabs_present": { "type": "boolean" },
    "session_history_view_present": { "type": "boolean" },
    "session_history_read_only": { "const": true },
    "session_history_loaded": { "type": "boolean" },
    "session_history_count": { "type": "integer", "minimum": 0 },
    "session_result_open_explicit": { "const": true },
    "session_receipt_open_explicit": { "const": true },
    "session_folder_open_explicit": { "const": true },
    "session_repair_relationships_inferred": { "const": false },
    "diagnostics_view_present": { "type": "boolean" },
    "diagnostics_collect_explicit": { "const": true },
    "diagnostics_export_explicit": { "const": true },
    "diagnostics_snapshot_loaded": { "type": "boolean" },
    "diagnostics_export_completed": { "type": "boolean" },
    "workspaces_root": { "type": "string" },
    "qt_version": { "type": "string" },
    "pyside_version": { "type": "string" },
    "python_version": { "type": "string" },
    "qt_platform": { "type": "string" },
    "event_loop_exit_code": { "type": "integer" },
    "timed_out": { "type": "boolean" },
    "error_code": { "type": "string" },
    "error": { "type": "string" },
    "install_hint": { "type": "string" }
  }
}

{
  "manifest_version": 3,
  "name": "Bartosz Dev Bridge",
  "version": "0.2.9",
  "description": "Bounded local project creation, workspace context, tested edits, recoverable AUTO state, confirmed continuation, verified promotion, and one-click ChatGPT prompt handoff.",
  "permissions": [
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background_full_entry.js"
  },
  "action": {
    "default_title": "Bartosz Dev Bridge",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "content.js",
        "content_rerender.js",
        "content_auto_send.js",
        "content_auto_retry.js",
        "content_project_launcher.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ]
}
